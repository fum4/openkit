{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "paths": {
      "@openkit/shared/*": ["./libs/shared/src/*"],
      "@openkit/logger": ["./libs/logger/node/src/index.ts"]
    }
  },
  "include": [
    "apps/**/*.ts",
    "apps/**/*.tsx",
    "apps/**/*.d.ts",
    "apps/**/*.cjs",
    "global.d.ts",
    "md.d.ts"
  ],
  "exclude": ["node_modules", "dist", "apps/mobile-app/**"]
}
