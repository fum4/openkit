{
  "name": "logger",
  "sourceRoot": "libs/logger",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "commands": ["pnpm build:cgo", "pnpm build:wasm"],
        "cwd": "libs/logger",
        "parallel": true
      },
      "inputs": [
        "{projectRoot}/src/**/*.go",
        "{projectRoot}/go.mod",
        "{projectRoot}/src/targets/cgo/**/*.go",
        "{projectRoot}/src/targets/cgo/go.mod",
        "{projectRoot}/src/targets/cgo/build.sh",
        "{projectRoot}/src/bindings/**/*.ts",
        "{projectRoot}/src/targets/wasm/**/*.go",
        "{projectRoot}/src/targets/wasm/go.mod",
        "{projectRoot}/src/bindings/zig/**/*.zig"
      ],
      "outputs": [
        "{projectRoot}/dist/liblogger.dylib",
        "{projectRoot}/dist/liblogger.so",
        "{projectRoot}/dist/liblogger.h",
        "{projectRoot}/dist/logger.wasm",
        "{projectRoot}/dist/wasm_exec.js"
      ]
    }
  },
  "tags": ["type:library", "lang:go", "lang:typescript", "lang:python", "lang:zig"]
}
