{
  "name": "logger",
  "sourceRoot": "libs/logger",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "commands": ["cd cgo && ./build.sh", "cd wasm && ./build.sh"],
        "cwd": "libs/logger",
        "parallel": true
      },
      "inputs": [
        "{projectRoot}/*.go",
        "{projectRoot}/go.mod",
        "{projectRoot}/cgo/**/*.go",
        "{projectRoot}/cgo/go.mod",
        "{projectRoot}/cgo/build.sh",
        "{projectRoot}/node/src/**/*.ts",
        "{projectRoot}/wasm/**/*.go",
        "{projectRoot}/wasm/go.mod",
        "{projectRoot}/zig/**/*.zig"
      ],
      "outputs": [
        "{projectRoot}/liblogger.dylib",
        "{projectRoot}/liblogger.so",
        "{projectRoot}/liblogger.h",
        "{projectRoot}/browser/src/logger.wasm",
        "{projectRoot}/browser/src/wasm_exec.js"
      ]
    },
    "check:types": {
      "executor": "nx:run-commands",
      "options": {
        "commands": ["cd node && pnpm check:types", "cd browser && pnpm check:types"],
        "cwd": "libs/logger",
        "parallel": true
      }
    },
    "check:format": {
      "executor": "nx:run-commands",
      "options": {
        "commands": ["cd node && pnpm check:format", "cd browser && pnpm check:format"],
        "cwd": "libs/logger",
        "parallel": true
      }
    },
    "check:lint": {
      "executor": "nx:run-commands",
      "options": {
        "commands": ["cd node && pnpm check:lint", "cd browser && pnpm check:lint"],
        "cwd": "libs/logger",
        "parallel": true
      }
    },
    "fix:format": {
      "executor": "nx:run-commands",
      "options": {
        "commands": ["cd node && pnpm fix:format", "cd browser && pnpm fix:format"],
        "cwd": "libs/logger",
        "parallel": true
      }
    },
    "fix:lint": {
      "executor": "nx:run-commands",
      "options": {
        "commands": ["cd node && pnpm fix:lint", "cd browser && pnpm fix:lint"],
        "cwd": "libs/logger",
        "parallel": true
      }
    }
  },
  "tags": ["type:library", "lang:go", "lang:typescript", "lang:python", "lang:zig"]
}
