{
  "name": "logger",
  "sourceRoot": "libs/logger",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "commands": ["cd cgo && ./build.sh", "cd wasm && ./build.sh"],
        "cwd": "libs/logger",
        "parallel": true
      },
      "inputs": [
        "{projectRoot}/*.go",
        "{projectRoot}/go.mod",
        "{projectRoot}/cgo/**/*.go",
        "{projectRoot}/cgo/go.mod",
        "{projectRoot}/cgo/build.sh",
        "{projectRoot}/node/src/**/*.ts",
        "{projectRoot}/wasm/**/*.go",
        "{projectRoot}/wasm/go.mod",
        "{projectRoot}/zig/**/*.zig"
      ],
      "outputs": [
        "{projectRoot}/liblogger.dylib",
        "{projectRoot}/liblogger.so",
        "{projectRoot}/liblogger.h",
        "{projectRoot}/browser/src/logger.wasm",
        "{projectRoot}/browser/src/wasm_exec.js"
      ]
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "commands": ["cd node && pnpm typecheck", "cd browser && pnpm typecheck"],
        "cwd": "libs/logger",
        "parallel": true
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "commands": ["cd node && pnpm lint", "cd browser && pnpm lint"],
        "cwd": "libs/logger",
        "parallel": true
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "libs/logger/node",
        "command": "pnpm test"
      }
    }
  },
  "tags": ["type:library", "lang:go", "lang:typescript", "lang:python", "lang:zig"]
}
