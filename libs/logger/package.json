{
  "name": "@openkit/logger",
  "private": true,
  "type": "module",
  "exports": {
    "./node": "./src/bindings/node/logger.ts",
    "./browser": "./src/bindings/browser/logger.ts"
  },
  "scripts": {
    "build:cgo": "cd src/targets/cgo && ./build.sh",
    "build:wasm": "cd src/targets/wasm && ./build.sh",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "check:types": "tsgo --noEmit -p tsconfig.json",
    "check:format": "oxfmt --check src/bindings",
    "check:lint": "oxlint src/bindings",
    "fix:format": "oxfmt src/bindings",
    "fix:lint": "oxlint --fix src/bindings"
  },
  "dependencies": {
    "koffi": "^2.15.2"
  }
}
