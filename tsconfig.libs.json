{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "paths": {
      "@openkit/shared/*": ["./libs/shared/src/*"]
    }
  },
  "include": [
    "libs/**/*.ts",
    "libs/**/*.tsx",
    "libs/**/*.d.ts",
    "libs/**/*.cjs",
    "global.d.ts",
    "md.d.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
