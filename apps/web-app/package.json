    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "happy-dom": "^20.8.3",
    "hono": "^4.12.3",
    "msw": "^2.12.10",
    "nanoid": "^5.1.6",
    "oxlint": "^1.50.0",
    "picocolors": "^1.1.1",
    "postcss": "^8.4.38",
    "tailwindcss": "^4.2.1",
    "vite": "^7.3.1",
    "zod": "^4.3.6"
