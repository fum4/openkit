{
  "name": "@openkit/web-app",
  "version": "0.0.58",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start": "pnpm exec nx run web-app:build && pnpm preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "check:types": "tsgo --noEmit -p tsconfig.json",
