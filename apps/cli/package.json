{
  "name": "@openkit/cli",
  "version": "0.0.60",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsup --watch --watch ../server/src --watch ../../libs",
    "build": "tsup",
    "preview": "node dist/cli/index.js",
    "start": "pnpm exec nx run cli:build && pnpm preview",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:unit:coverage": "vitest run --coverage",
    "check:types": "tsgo --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.0",
    "@openkit/agents": "workspace:*",
    "@openkit/integrations": "workspace:*",
    "@openkit/logger": "workspace:*",
    "@openkit/port-offset": "workspace:*",
    "@openkit/server": "workspace:*",
    "@openkit/shared": "workspace:*",
    "koffi": "^2.15.2",
    "node-pty": "1.2.0-beta.10",
    "picocolors": "^1.1.1",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "oxlint": "^1.50.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
