{
  "name": "@openkit/server",
  "version": "0.0.54",
  "private": true,
  "type": "module",
  "exports": {
    "./*": "./src/*.ts"
  },
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "preview": "node dist/standalone.js",
    "start": "pnpm exec nx run server:build && pnpm preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "check:types": "tsgo --noEmit -p tsconfig.json",
    "check:format": "oxfmt --check src",
    "check:lint": "oxlint src",
    "fix:format": "oxfmt src",
    "fix:lint": "oxlint --fix src"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.8",
    "@hono/node-ws": "^1.3.0",
    "@openkit/agents": "workspace:*",
    "@openkit/integrations": "workspace:*",
    "@openkit/logger": "workspace:*",
    "@openkit/port-offset": "workspace:*",
    "@openkit/shared": "workspace:*",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/headless": "^6.0.0",
    "hono": "^4.12.2",
    "koffi": "^2.15.2",
    "nanoid": "^5.1.6",
    "node-pty": "1.2.0-beta.10",
    "picocolors": "^1.1.1",
    "pidusage": "^4.0.1",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "@types/pidusage": "^2.0.5",
    "@types/ws": "^8.18.1",
    "memfs": "^4.56.11",
    "oxlint": "^1.50.0",
    "tsup": "^8.5.1"
  }
}
