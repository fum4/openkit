---
import DownloadSplitButton from "./DownloadSplitButton.astro";
---

<div class="section-divider"></div>
<section id="download">
  <div class="container">
    <h2 class="section-title fade-in"><svg class="title-icon" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>Download OpenKit</h2>
    <p class="section-sub fade-in" data-delay="80">
      Default selection follows your device. Use the right-side selector for all released builds.
    </p>
    <div class="download-card fade-in" data-delay="160">
      <div class="download-main">
        <DownloadSplitButton buttonId="download-btn" className="section-download glow-pulse" />
      </div>
      <a
        href="https://github.com/fum4/OpenKit/releases"
        target="_blank"
        rel="noopener"
        class="releases-link"
      >
        View all releases on GitHub &rarr;
      </a>
    </div>
  </div>
</section>

<style>
  .section-title {
    font-size: 36px;
    text-align: center;
    margin-bottom: 8px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 8px;
  }

  .title-icon {
    color: var(--text-muted);
  }

  .section-sub {
    font-size: 14px;
    color: var(--text-muted);
    text-align: center;
    margin-bottom: 40px;
  }

  .download-card {
    max-width: 420px;
    margin: 0 auto;
    background: var(--bg-panel);
    border: 1px solid var(--border-subtle);
    border-radius: 24px;
    padding: 32px;
    text-align: center;
  }

  .download-main {
    margin-bottom: 24px;
    display: flex;
    justify-content: center;
  }

  .section-download {
    width: 100%;
    max-width: 420px;
  }

  .section-download .download-main-btn {
    justify-content: center;
    width: calc(100% - 44px);
  }

  .releases-link {
    display: inline-block;
    margin-top: 4px;
    font-size: 13px;
    color: var(--text-muted) !important;
    transition: color 0.2s var(--ease-out-quart) !important;
  }

  .releases-link:hover {
    color: #fff !important;
  }

  @media (max-width: 768px) {
    .download-card {
      padding: 24px;
    }

    .section-title {
      font-size: 28px;
    }

    .section-download .download-main-btn {
      justify-content: flex-start;
    }
  }
</style>
