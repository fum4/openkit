{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "desktop-app",
  "projectType": "application",
  "sourceRoot": "apps/desktop-app/src",
  "targets": {
    "build": {
      "dependsOn": ["web-app:build", "cli:build", "server:build"],
      "outputs": ["{workspaceRoot}/apps/desktop-app/dist"]
    },
    "package": {
      "dependsOn": ["build"],
      "outputs": ["{workspaceRoot}/apps/desktop-app/release"]
    },
    "package:mac": {
      "dependsOn": ["build"],
      "outputs": ["{workspaceRoot}/apps/desktop-app/release"]
    },
    "package:linux": {
      "dependsOn": ["build"],
      "outputs": ["{workspaceRoot}/apps/desktop-app/release"]
    }
  }
}
