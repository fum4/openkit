{
  "name": "@openkit/desktop-app",
  "version": "0.0.64",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/fum4/openkit.git"
  },
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n desktop:compile,desktop:run -c yellow,magenta \"pnpm run compile\" \"pnpm run run\"",
    "build": "tsup",
    "preview": "wait-on ./dist/main.js ../web-app/dist/index.html ../cli/dist/cli/index.js ../server/dist/runtime/port-hook.cjs && electron ./dist/main.js",
    "start": "pnpm exec nx run desktop-app:build && pnpm preview",
    "compile": "tsup --watch",
    "run": "wait-on http://localhost:${OPENKIT_WEB_APP_PORT:-5173} ./dist/main.js ../cli/dist/cli/index.js && UI_DEV_SERVER_URL=http://localhost:${OPENKIT_WEB_APP_PORT:-5173} VITE_DEV_SERVER=1 electronmon ./dist/main.js",
    "package": "pnpm package:mac && pnpm package:linux",
    "package:mac": "pnpm exec electron-builder --config electron-builder.yml --mac --publish never",
    "package:linux": "pnpm exec electron-builder --config electron-builder.yml --linux AppImage --publish never",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:unit:coverage": "vitest run --coverage",
    "check:types": "tsgo --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@openkit/logger": "workspace:*",
    "@openkit/shared": "workspace:*",
    "electron-updater": "^6.8.3",
    "node-pty": "1.2.0-beta.10",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "@types/node": "^25.3.0",
    "concurrently": "^9.2.1",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "electronmon": "^2.0.4",
    "oxlint": "^1.50.0",
    "tsup": "^8.5.1",
    "vitest": "^4.0.18",
    "wait-on": "^9.0.4"
  }
}
